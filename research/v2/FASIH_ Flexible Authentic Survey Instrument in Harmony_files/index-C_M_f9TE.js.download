      <!DOCTYPE html>
      <html lang="en">
        <head>
          <meta charset="UTF-8">
          <meta name="viewport" content="width=device-width, initial-scale=1.0">
          <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { margin: 0; padding: 0; overflow: auto; }
            #form-root { width: 100%; min-height: 100vh; }
          </style>
          <style id="form-engine-css">${p.data}</style>
        </head>
        <body>
          <div id="form-root"></div>
          <script id="form-engine-js">${m.data}<\/script>
          <script>
            let parentOrigin = null;
            let formInitialized = false;

            function initForm(config) {
              if (formInitialized) {
                console.warn("Form already initialized, skipping...");
                return;
              }
              
              try {
                parentOrigin = config.parentOrigin;
                if (!parentOrigin) 
                  throw new Error("Parent origin not provided.");

                if (typeof window.FasihForm !== "function") 
                  throw new Error("fasih form not loaded");
                
                const form = window.FasihForm("#form-root", {
                  template: config.template,
                  validation: config.validation,
                  initialMode: config.initialMode,
                  formMode: config.formMode,
                  user: config.user,
                  response: config.response || {},
                  preset: {},
                  remark: {},
                  principals: []
                });
                     
                form.event.on("submit", ({ principal, remark, response }) => {
                  try {
                    const serializedPayload = JSON.parse(JSON.stringify({ principal, remark, response }));
                    window.parent.postMessage({ 
                      type: "FORM_SUBMIT", 
                      payload: serializedPayload 
                    }, parentOrigin);
                  } catch (err) {
                    window.parent.postMessage({ 
                      type: "FORM_ERROR", 
                      payload: { message: "Failed to serialize form data: " + err.message } 
                    }, parentOrigin);
                  }
                });
                
                form.event.on("lookup-request", async (lookupConfig, params) => {
                  const requestId = Date.now() + Math.random();
                  
                  window.parent.postMessage({ 
                    type: "LOOKUP_REQUEST", 
                    payload: { requestId, config: lookupConfig, params } 
                  }, parentOrigin);
                  
                  return new Promise((resolve, reject) => {
                    const timeout = setTimeout(() => {
                      cleanup();
                      reject(new Error("Lookup timeout"));
                    }, 10000); 
                    
                    const handler = (event) => {
                      if (event.origin !== parentOrigin) return;

                      if (event.data.type === "LOOKUP_RESPONSE" && event.data.requestId === requestId) {
                        cleanup();
                        resolve(event.data.payload);
                      }
                    };
                    
                    const cleanup = () => {
                      clearTimeout(timeout);
                      window.removeEventListener("message", handler);
                    };
                    
                    window.addEventListener("message", handler);
                  });
                });
                
                form.render();
                window.formInstance = form;
                formInitialized = true;
                window.parent.postMessage({ type: "FORM_READY" }, parentOrigin);
              } catch (error) {
                if (parentOrigin) {
                  window.parent.postMessage({ type: "FORM_ERROR", payload: { message: error.message } }, parentOrigin);
                }
              }
            }
            
            window.addEventListener("message", (event) => {
              if (event.data.type === "INIT_FORM") {
                initForm(event.data.payload);
              }
            });

            window.parent.postMessage({ type: "IFRAME_READY" }, "*");
          <\/script>
        </body>
      </html>
