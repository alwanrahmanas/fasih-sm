 one mode is selected`,"form.validation.mode-max-length":`Maximum four modes are selected`,"form.validation.mode-duplicate":`Survey modes must be unique`,"form.validation.region-required":`Survey region is required`,"form.validation.period-min-length":`Please add at least one survey period`,"form.validation.template-min-length":`Please add at least one survey template`,"form.survey-detail":`Survey Details`,"form.survey-detail-desc":`Fill in the basic information about your survey`,"form.label.name":`Survey Name`,"form.label.description":`Survey Description`,"form.label.type":`Survey Type`,"form.label.type-select":`Select survey type`,"form.label.modes":`Survey Modes`,"form.label.modes-select":`Select survey modes`,"form.survey-general":`General Survey Settings`,"form.survey-general-desc":`Configure additional survey requirements and settings`,"form.label.region":`Master Region`,"form.label.region-search":`Search Region`,"form.label.region-placeholder":`Search with region name...`,"form.label.region-not-found":`Region not found`,"form.label.general":`Additional Settings`,"form.label.panel":`Panel Survey`,"form.label.panel-desc":`Make this a panel survey`,"form.label.listing":`Updating/Listing Survey`,"form.label.listing-desc":`Make this an updating survey`,"form.label.autoAssignSample":`Auto-Assign When Uploading Sample`,"form.label.autoAssignSample-desc":`When uploading samples, surveyors can be assigned automatically`,"form.label.addSample":`Can Add Sample`,"form.label.addSample-desc":`During data collection, surveyors can add new samples`,"form.label.autoGenerateToken":`Auto-Generate CAWI Token`,"form.label.autoGenerateToken-desc":`CAWI tokens will be generated automatically`,"form.period.label.name":`Period Name`,"form.period.label.start-date":`Start Date`,"form.period.label.start-date-select":`Select Start Date`,"form.period.label.end-date":`End Date`,"form.period.label.end-date-select":`Select End Date`,"form.template.version":`Template Version`,"form.template.